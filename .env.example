# ==============================================================================
# AI Online Judge — Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to '.env' before running 'make up' or 'docker-compose up':
#   cp .env.example .env
#
# NOTE: '.env' is listed in .gitignore. Never commit real production secrets!
# ==============================================================================

# ── 1. PostgreSQL Database Infrastructure ─────────────────────────────────────
# Primary data store for users, problems, and Educational Data Mining (EDM) logs.
# Generate a secure password via terminal: openssl rand -base64 32
POSTGRES_PASSWORD=secure_postgres_password_here

# ── 2. RabbitMQ Message Broker (AMQP) ─────────────────────────────────────────
# Decouples API Gateway from isolated Judge0 workers with ACK/NACK guarantees.
# Generate a secure password via terminal: openssl rand -base64 32
RABBITMQ_PASSWORD=secure_rabbitmq_password_here

# ── 3. JSON Web Token (JWT) Authentication Secret ─────────────────────────────
# Enforced across protected API Gateway routes and WebSocket handshakes using HMAC-SHA256.
# Generate a secure 256-bit secret via terminal: openssl rand -base64 32
JWT_SECRET=secure_256bit_jwt_secret_key_here

# ── 4. OpenAI API Configuration (Virtual TA / AI Tutor Service) ───────────────
# Powers the Socratic Virtual TA microservice. Must have access to GPT-4o.
# Obtain an API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-real-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── 5. Sandboxed Code Execution Engine (Judge0) ───────────────────────────────
# URL pointing to the Judge0 API instance wrapping Linux namespaces and cgroups v2.
# By default points to public CE instance or internal Docker service.
JUDGE0_URL=https://ce.judge0.com

# ── 6. Next.js Frontend Client-Side Environment Variables ─────────────────────
# Exposed to browser bundle to route REST and WebSocket traffic to API endpoints.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8082

# ── 7. Admin Account Auto-Seeding on Startup ──────────────────────────────────
# The API Gateway automatically creates or updates the admin account on boot.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword123
ADMIN_EMAIL=admin@aioj.studio
